# Generated sprite metadata. Existing tracked files require `git rm --cached`
# before this ignore rule can prevent diffs; keep source-of-truth edits in
# tools/ambition_sprite2d_renderer targets/configs instead.
crates/ambition_gameplay_core/assets/sprites/*.ron
crates/ambition_gameplay_core/assets/sprites/**/*.ron

# Sprite renderer generated package outputs
tools/ambition_sprite2d_renderer/ambition_sprite2d_renderer/generated/
tools/ambition_sprite2d_renderer/ambition_sprite2d_renderer/targets/generated/

# Generated sprite YAML sidecars; runtime uses *_spritesheet.ron.
crates/ambition_gameplay_core/assets/sprites/*_spritesheet.yaml
crates/ambition_gameplay_core/assets/sprites/**/*_spritesheet.yaml

# Agent/worktree scratch (must never be committed)
.worktrees/
.tmp-ambition-agent-source-*/
