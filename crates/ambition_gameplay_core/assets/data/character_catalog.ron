            tags: ["hub", "peaceful"],
        barks: (
            on_hit: ["Spell disrupted!", "Concentration broken!", "Ow! My focus!"],
            provoked: ["Casting hostile mode!"],
            idle: ["The incantation requires silence.", "Energy patterns are complex today.", "Something is forming just out of perception."],
            hall: ["Casting... atmosphere. The hall felt empty before me. Now it doesn't.", "No fireball. Just the sense someone's paying attention."],
        ),
        hall_dialogue_id: Some("hall_npc_robot_caster"),
        ),
        "npc_robot_diver": (
