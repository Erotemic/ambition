            provoked: ["Emergency ascent!"],
            idle: ["The depths are quiet. This is not the depths.", "Current estimate: twelve meters, metaphorically.", "Always check your equipment before descent."],
            hall: ["Decompressing. Slowly. The surface is louder than the deep.", "I miss the pressure. It told me which way was up by squeezing."],
        ),
        hall_dialogue_id: Some("hall_npc_robot_diver"),
        ),
        "npc_robot_engineer": (
            display_name: "Robot Engineer",
