            idle: ["Something could always be more efficient.", "The tolerances are tighter than they look.", "That's not how it's supposed to work, but it works."],
            hall: ["I could improve this hall's throughput by about 34%. Nobody asked.", "The exhibit design is fine. Not optimal. Fine.", "I see the cable routing from up here. I won't say what I think about it."],
        ),
        hall_dialogue_id: Some("hall_npc_robot_engineer"),
        ),
