            provoked: ["DEFENSE PROTOCOL: MAXIMUM."],
            hall: ["Threat: low. Recomputed three times since I said that.", "A snapshot is a lie the instant it's taken. So I keep taking them."],
        ),
        hall_dialogue_id: Some("hall_npc_robot_guardian"),
        ),
