        "npc_pirate_heavy_broadside_bess": (
            sprite_tuning: Some((collision_scale: 1.95, frame_sample_inset: 1)),
            display_name: "Broadside Bess",
            spritesheet: "sprites/pirate_heavy_broadside_bess_spritesheet.png",
