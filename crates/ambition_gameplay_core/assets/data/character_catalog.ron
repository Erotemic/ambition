        hall_dialogue_id: Some("hall_npc_general_hero"),
        ),
        "npc_ghoul_skulker": (
            display_name: "Ghoul Skulker",
            spritesheet: "sprites/ghoul_skulker_spritesheet.png",
            manifest: "sprites/ghoul_skulker_spritesheet.ron",
            tier: MainHall,
            body_kind: Standard,
            composition: None,
            default_brain: "melee_brute_striker",
            default_action_set: "striker_swipe",
            tags: ["enemy"],
        barks: (
            on_hit: ["Yeeaaargh!", "This flesh already hurts!", "STOP HITTING THE GHOUL."],
            provoked: ["Skulking intensifies!"],
            hall: ["Being dead is mostly a posture problem.", "Held together by spite and good intentions. Mostly spite."],
        ),
        hall_dialogue_id: Some("hall_npc_ghoul_skulker"),
        ),
        "npc_girdle": (
            display_name: "Girdle",
            spritesheet: "sprites/girdle_spritesheet.png",
            manifest: "sprites/girdle_spritesheet.ron",
            tier: MainHall,
            body_kind: Standard,
            composition: None,
            default_brain: "patrol_peaceful",
            default_action_set: "peaceful",
            tags: ["hub", "peaceful"],
        barks: (
            on_hit: ["That hurts!", "Do you mind?", "Uncalled for!"],
            provoked: ["I am done being pleasant!"],
            idle: ["I hold things together around here.", "Structure is underappreciated.", "Nobody asks how I'm doing."],
            hall: ["Every sound system hides a truth it can't reach. I checked yours.", "Is the food safe? Is the logic? I worry about both."],
        ),
        hall_dialogue_id: Some("hall_npc_girdle"),
        ),
        "npc_gnu_ton_boss": (
            display_name: "Gnu Ton Boss",
            spritesheet: "sprites/gnu_ton_boss/gnu_ton_boss_spritesheet.png",
            manifest: "sprites/gnu_ton_boss/gnu_ton_boss_spritesheet.ron",
            tier: Basement,
            body_kind: Wide,
            composition: None,
            default_brain: "stand_still",
            default_action_set: "peaceful",
            tags: ["boss", "placeholder_brain"],
        barks: (
            on_hit: ["Counterfeit.", "You ring false.", "Assayed. Found wanting.", "Your defiance has mass.", "Pain is data.", "Impact is merely mathematics becoming honest.", "The hypothesis has failed. Begin dissection.", "Your continued existence is statistically irritating.", "I tire of imprecision."],
            idle: ["Fall. I have already solved for where.", "The universe is not cruel. It is exact.", "I have split the sun. I can divide you.", "I know false weight when it breathes.", "Your motion was inevitable.", "I require no prophecy to know your end.", "Do not resist the law. You are made of it.", "I have measured the heavens. You are a rounding error.", "Every body attracts every other. Unfortunately for you, I am very large.", "You are not escaping. You are tracing a curve.", "Be still. I am observing.", "Hold steady. The experiment requires repetition.", "The prism does not lie. It only reveals the lie.", "Your shadow has an angle. Your death has a proof.", "Lead dreams of gold. Flesh dreams of dust.", "The furnace corrects all impurities.", "Mercury remembers the shape of every sin.", "Be transmuted.", "The world is a crucible, and you are not the gold.", "Impurity is just matter confessing.", "History is a cipher. You are a solved term.", "The end is not near. It is numbered.", "I do not predict. I calculate.", "Even apocalypse obeys arithmetic.", "God wrote in number. I learned to read.", "Creation is not chaos. It is a ledger.", "You mistake mystery for permission.", "The stars keep their stations. Learn from them.", "You are light coin.", "Clipped, debased, and due for hanging.", "Bring the scales.", "The stamp shall reveal your value.", "I have sent better men to the gallows for less.", "Fraud always leaves a shaving.", "Enough observation. Now comes proof.", "You have survived the question. Face the answer.", "Let us remove the remaining variables.", "No more approximations.", "Let the heavens fall inward.", "Now every law acts at once.", "The calculation accelerates.", "Your margin of error is closed.", "The proof concludes."],
            hall: ["You're falling toward me right now. Too slowly to be polite about it.", "An apple taught me everything. The apple asked for nothing."],
        ),
        hall_dialogue_id: Some("hall_npc_gnu_ton_boss"),
        ),
        "npc_goblin_brute_hammer": (
            display_name: "Goblin Brute Hammer",
            spritesheet: "sprites/goblin_brute_hammer_spritesheet.png",
            manifest: "sprites/goblin_brute_hammer_spritesheet.ron",
            tier: MainHall,
            body_kind: Wide,
            composition: None,
            default_brain: "melee_brute_brute",
            default_action_set: "brute_lunge",
            tags: ["enemy", "heavy"],
        barks: (
            on_hit: ["GNNH!", "Hammer. HAMMER.", "Brute smash!"],
            provoked: ["HAMMER TIME."],
            hall: ["Hammer wants to work. Hammer is sad.", "Brute good at the part after the talking."],
        ),
        hall_dialogue_id: Some("hall_npc_goblin_brute_hammer"),
        ),
        "npc_goblin_cave_dagger": (
            display_name: "Goblin Cave Dagger",
            spritesheet: "sprites/goblin_cave_dagger_spritesheet.png",
