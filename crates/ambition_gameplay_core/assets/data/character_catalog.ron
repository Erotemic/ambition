            provoked: ["Engagement: open fire!"],
            hall: ["Standing still. Every instinct screaming. Coping.", "If I can't reposition, I'll just be unbearably accurate. Adjusting."],
        ),
        hall_dialogue_id: Some("hall_npc_ranged_skirmisher"),
