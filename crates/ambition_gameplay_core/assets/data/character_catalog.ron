            tags: ["hub", "peaceful"],
        barks: (
            on_hit: ["Excuse me!", "I beg your pardon!", "That was rude!"],
            provoked: ["You leave me no choice!"],
            idle: ["I've been meaning to reorganize my routes.", "Everything is fine. Fine.", "There's supposed to be a sign here. I've filed a request."],
            hall: ["Judy stands here, on display, with her dignity mostly intact.", "I filled out the exhibit form correctly, which is more than most can say.", "The hall is well-organized. I know because I checked."],
        ),
        hall_dialogue_id: Some("hall_npc_judy"),
