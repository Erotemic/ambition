            tags: ["boss", "placeholder_brain"],
        barks: (
            on_hit: ["Ramen!", "TOUCHED BY HIS NOODLY APPENDAGE — no wait, that was me touching you.", "The sauce thickens!"],
            provoked: ["Marinara mode: engaged!"],
            idle: ["Pasta la vista.", "I have created you all with my noodly appendages.", "The sauce of creation is bottomless."],
            hall: ["You have been touched by my noodly presence, and that is a miracle.", "I gave everyone free will and this is what happens.", "The plinth was anointed with marinara. You're welcome."],
        ),
        hall_dialogue_id: Some("hall_npc_flying_spaghetti_monster_boss"),
        ),
        "npc_galwah": (
