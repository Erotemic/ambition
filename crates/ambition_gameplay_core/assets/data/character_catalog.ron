            provoked: ["Charge!"],
            hall: ["Trees keep secrets better than people. I trust trees.", "Forest goblin counts the exits by smell. Two. Both wrong-smelling."],
        ),
        hall_dialogue_id: Some("hall_npc_goblin_forest_spear"),
        ),
        // Sandbox kiter enemy (CharacterArchetype::RangedSkirmisher). The spawn's
