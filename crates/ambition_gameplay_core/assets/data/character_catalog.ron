            provoked: ["Drawing!"],
            hall: ["Desert goblin misses the sky. Museum has ceiling.", "Range: zero. Plinth too high.", "Sand in exhibit is from me. I don't apologize."],
        ),
        hall_dialogue_id: Some("hall_npc_goblin_desert_bow"),
        ),
        "npc_goblin_forest_spear": (
            display_name: "Goblin Forest Spear",
