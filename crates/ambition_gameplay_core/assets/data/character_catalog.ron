// Character catalog — single source of truth for spawnable
// characters in the sandbox. See
// `crates/ambition_gameplay_core/src/content/character_catalog/` for the
// loader + resolver, and `TODO-character-catalog-and-hall.md` for
// the architectural posture (Rust = behavior, RON = content, LDtk
// = space).
//
// Schema: see `content/character_catalog/entry.rs::CharacterCatalogData`.
//
// To add a new character: pick a `brain_presets` key + an
// `action_set_presets` key, then add a row to `characters` with the
// sprite paths and tier. No Rust changes needed.

(
    brain_presets: {
        "stand_still": StandStill,
        "patrol_peaceful": Patrol(
            spawn_local_x: 0.0,
            radius: 64.0,
            speed: 28.0,
            aggressiveness: 0.0,
            aggro_radius: 80.0,
            attack_range: 0.0,
        ),
        "wanderer_puppy_slug": Wanderer(
            speed: 36.0,
            climb_walls: true,
            chatter_threshold: 3,
            chatter_window_s: 1.0,
            chatter_pause_s: 2.0,
            aggressiveness: 0.0,
        ),
        "melee_brute_striker": MeleeBrute(
            aggressiveness: 1.0,
            aggro_radius: 220.0,
            attack_range: 36.0,
            chase_speed: 110.0,
        ),
        "melee_brute_brute": MeleeBrute(
            aggressiveness: 1.0,
            aggro_radius: 240.0,
            attack_range: 44.0,
            chase_speed: 75.0,
        ),
        "skirmisher_ranger": Skirmisher(
            aggressiveness: 1.0,
            aggro_radius: 320.0,
            standoff_px: 140.0,
            strafe_speed: 85.0,
            fire_cooldown_s: 0.8,
        ),
        "sniper_default": Sniper(
            aggressiveness: 1.0,
            aggro_radius: 480.0,
            fire_cooldown_s: 1.5,
        ),
        // Lively peaceful flyer (the cove parrot): flits between airborne perches
        // and ground spots, and drops down beside the player to be talked to.
        // Needs a `Floating` body_kind (gravity-free) to actually fly.
        "parrot_lively": Aerial(
            aggressiveness: 0.0,
            cruise_speed: 95.0,
            dive_speed: 240.0,
            aggro_radius: 120.0,
            attack_range: 0.0,
            roam_radius: 130.0,
        ),
        // Aggressive flying melee archetype for the Perfect Cellular Automaton.
        // The body must be `Floating` so the Aerial brain's 2D velocity drives
        // the fly row instead of walking on the ground.
        "cellular_automaton_raider": Aerial(
            aggressiveness: 1.0,
            cruise_speed: 88.0,
            dive_speed: 210.0,
            aggro_radius: 220.0,
            attack_range: 42.0,
            roam_radius: 144.0,
        ),
    },

    action_set_presets: {
        "peaceful": (
            move_style: Walk,
            melee: None,
            ranged: None,
            special: None,
        ),
        "peaceful_float": (
            move_style: Float,
            melee: None,
            ranged: None,
            special: None,
        ),
        "peaceful_slither": (
            move_style: Slither,
            melee: None,
            ranged: None,
            special: None,
        ),
        "striker_swipe": (
            move_style: Walk,
            melee: Some(Swipe(
                windup_s: 0.28,
                active_s: 0.08,
                recover_s: 0.32,
                damage: 1,
                reach_px: 28.0,
            )),
            ranged: None,
            special: None,
        ),
        "brute_lunge": (
            move_style: WalkHeavy,
            melee: Some(Lunge(
                windup_s: 0.45,
                active_s: 0.12,
                recover_s: 0.45,
                damage: 2,
                reach_px: 40.0,
                step_px: 18.0,
            )),
            ranged: None,
            special: None,
        ),
        "ranger_arrow": (
            move_style: Strafe,
            melee: None,
            ranged: Some(Arrow(speed: 520.0, damage: 2)),
            special: None,
        ),
        "pirate_pistol": (
            move_style: Walk,
            melee: Some(Swipe(
                windup_s: 0.28,
                active_s: 0.08,
                recover_s: 0.32,
                damage: 1,
                reach_px: 28.0,
            )),
            ranged: Some(Pistol(speed: 480.0, damage: 1)),
            special: None,
        ),
        "sandbag_punch": (
            move_style: Walk,
            melee: Some(PunchWeak(
                windup_s: 0.15,
                active_s: 0.08,
                recover_s: 0.40,
                damage: 1,
                reach_px: 22.0,
            )),
            ranged: None,
            special: None,
        ),
    },

    characters: {
        // ===== Base characters (player, robot, goblin, sandbag). The
        // player slot is special-cased by the runtime (Brain::Player);
        // its catalog entry exists only to keep the sprite registry
        // and catalog symmetrical so Phase 6 can delete the registry.
        "player": (
            sprite_tuning: Some((collision_scale: 1.35, frame_sample_inset: 1)),
            display_name: "Player",
            spritesheet: "sprites/player_robot_spritesheet.png",
            manifest: "sprites/player_robot_spritesheet.ron",
            tier: MainHall,
            body_kind: Standard,
            composition: None,
            default_brain: "stand_still",
            default_action_set: "peaceful",
            tags: ["player"],
        barks: (
            hall: ["I'm the player character. This is deeply recursive.", "Am I on display, or are you?"],
        ),
        hall_dialogue_id: Some("hall_player"),
        ),
        "robot": (
            sprite_tuning: Some((collision_scale: 2.1, frame_sample_inset: 1)),
            display_name: "Robot",
            spritesheet: "sprites/robot_spritesheet.png",
            manifest: "sprites/robot_spritesheet.ron",
            tier: MainHall,
            body_kind: Standard,
            composition: None,
            default_brain: "stand_still",
            default_action_set: "peaceful",
            tags: ["base"],
        barks: (
            hall: ["I am a robot. I have been in this catalog since the beginning.", "The player started as me. I try not to think about it too hard."],
        ),
        hall_dialogue_id: Some("hall_robot"),
        ),
        "goblin": (
            sprite_tuning: Some((collision_scale: 2.1, frame_sample_inset: 1)),
            display_name: "Goblin",
            spritesheet: "sprites/goblin_spritesheet.png",
            manifest: "sprites/goblin_spritesheet.ron",
            tier: MainHall,
            body_kind: Standard,
            composition: None,
            default_brain: "melee_brute_striker",
            default_action_set: "striker_swipe",
            tags: ["enemy", "base"],
        barks: (
            on_hit: ["Gah! Watch it!", "Dirty trick!", "I'll remember that!"],
            provoked: ["Come on then!"],
            hall: ["They put ME in a museum? The gall.", "There are like thirty of me here. None of us consented."],
        ),
        hall_dialogue_id: Some("hall_goblin"),
        ),
        "sandbag": (
            sprite_tuning: Some((collision_scale: 1.38, frame_sample_inset: 1)),
            display_name: "Sandbag",
            spritesheet: "sprites/sandbag_spritesheet.png",
            manifest: "sprites/sandbag_spritesheet.ron",
            tier: MainHall,
            body_kind: Standard,
            composition: None,
            default_brain: "stand_still",
            default_action_set: "sandbag_punch",
            tags: ["training"],
        barks: (
            on_hit: ["..."],
            hall: ["I accept my role with dignity.", "I cannot move. I cannot speak. But I am here, and that matters."],
        ),
        hall_dialogue_id: Some("hall_sandbag"),
        ),

        // ===== Faction leaders (hub NPCs).
        "npc_general": (
            sprite_tuning: Some((collision_scale: 1.15, frame_sample_inset: 2)),
            display_name: "General",
            spritesheet: "sprites/absurd_general_spritesheet.png",
            manifest: "sprites/absurd_general_spritesheet.ron",
            tier: MainHall,
            body_kind: Standard,
            composition: None,
            default_brain: "patrol_peaceful",
            default_action_set: "peaceful",
            tags: ["hub", "faction_leader"],
        barks: (
            on_hit: ["Soldier, explain yourself.", "That is insubordination.", "Court-martial posture engaged."],
            provoked: ["Weapons free!"],
            hall: ["A general stands where placed. The plinth is adequate.", "I have reviewed this hall's defensive positions. Suboptimal.", "The enemy does not respect museum hours."],
        ),
        hall_dialogue_id: Some("hall_npc_general"),
        ),
        "npc_goblin_cantina_chieftain": (
            sprite_tuning: Some((collision_scale: 1.16, frame_sample_inset: 1)),
            display_name: "Fretjaw, Cantina Chieftain",
            spritesheet: "sprites/goblin_cantina_chieftain_spritesheet.png",
            manifest: "sprites/goblin_cantina_chieftain_spritesheet.ron",
            tier: MainHall,
            body_kind: Standard,
            composition: None,
            default_brain: "patrol_peaceful",
            default_action_set: "peaceful",
            tags: ["hub", "faction_leader"],
        barks: (
            on_hit: ["Oi! That's my good arm.", "Fretjaw bites back!", "Cantina rules: no free hits!"],
            provoked: ["Cantina brawl!"],
            hall: ["Fretjaw on a plinth! Very dignified. Very tall.", "They spelled it right. Fretjaw is impressed.", "The cantina sends its regards. Mostly threats."],
        ),
        hall_dialogue_id: Some("hall_npc_goblin_cantina_chieftain"),
        ),
        "npc_pulse_voyager_captain": (
            sprite_tuning: Some((collision_scale: 1.2, frame_sample_inset: 1)),
            display_name: "Captain Pulse",
            spritesheet: "sprites/pulse_voyager_captain_spritesheet.png",
            manifest: "sprites/pulse_voyager_captain_spritesheet.ron",
            tier: MainHall,
            body_kind: Standard,
            composition: None,
            default_brain: "patrol_peaceful",
            default_action_set: "peaceful",
            tags: ["hub", "faction_leader"],
        barks: (
            on_hit: ["Easy on the hull, starling.", "That's not standard docking procedure.", "Pulse shields to angry!"],
            provoked: ["Red alert, traveler!"],
            hall: ["Captain Pulse. On display. In a hall. Between a goblin and a pirate.", "The stars don't wait for museum hours.", "I've captained worse postings. Barely."],
        ),
        hall_dialogue_id: Some("hall_npc_pulse_voyager_captain"),
        ),
        "npc_tech_bro_disruptor": (
            sprite_tuning: Some((collision_scale: 1.2, frame_sample_inset: 1)),
            display_name: "Chadwick Disruptor III",
            spritesheet: "sprites/tech_bro_disruptor_spritesheet.png",
            manifest: "sprites/tech_bro_disruptor_spritesheet.ron",
            tier: MainHall,
            body_kind: Standard,
            composition: None,
            default_brain: "patrol_peaceful",
            default_action_set: "peaceful",
            tags: ["hub", "faction_leader"],
        barks: (
            on_hit: ["Bro. Optics.", "My brand is literally disruption.", "I'm posting about this."],
            provoked: ["You just activated my pivot."],
            hall: ["This hall is actually perfect brand positioning for me.", "I disrupted the museum paradigm by being IN it.", "The plinth needs to be slightly taller. I have notes."],
        ),
        hall_dialogue_id: Some("hall_npc_tech_bro_disruptor"),
        ),

        // ===== Symmetry tutorial (Noether Chamber).
        "npc_noether": (
            sprite_tuning: Some((collision_scale: 1.1, frame_sample_inset: 2)),
            display_name: "Emmy No-Ether",
            spritesheet: "sprites/noether_spritesheet.png",
            manifest: "sprites/noether_spritesheet.ron",
            tier: MainHall,
            body_kind: Standard,
            composition: None,
            default_brain: "stand_still",
            default_action_set: "peaceful",
            tags: ["hub", "guide", "tutorial"],
        barks: (
            on_hit: ["That violated several conservation laws.", "Every action has an equal and opposite consequence.", "The symmetry is broken now. Happy?"],
            provoked: ["By Noether's theorem — you're done!"],
            idle: ["Every symmetry hides a conservation law.", "The world is more beautiful when you find the invariant.", "Mathematics does not care what you believe."],
            hall: ["A theorem is just a truth that was patient enough to be found.", "I would lecture you on Lagrangian mechanics but we only have a plinth's worth of time.", "The hall itself has a symmetry, if you look carefully."],
        ),
        hall_dialogue_id: Some("hall_npc_noether"),
        ),

        // ===== Pirate cove (Pirate Cove faction).
        "npc_pirate_admiral": (
            sprite_tuning: Some((collision_scale: 1.6, frame_sample_inset: 1)),
            display_name: "Pirate Admiral",
            spritesheet: "sprites/pirate_admiral_spritesheet.png",
            manifest: "sprites/pirate_admiral_spritesheet.ron",
            tier: MainHall,
            body_kind: Standard,
            composition: None,
            default_brain: "melee_brute_striker",
            default_action_set: "pirate_pistol",
            tags: ["pirate", "faction_leader"],
            // SCAFFOLD exemplar (catalog-first overrides the legacy npcs.rs
            // table). on_hit/provoked migrated from features::npcs.
            barks: (
                on_hit: [
                    "Belay that, ye barnacle!",
                    "Mind the epaulettes, scallywag!",
                    "Avast — that be admiralty property!",
                    "I'll keelhaul yer cooldowns!",
                ],
                provoked: ["Broadside, ye bilge rat!"],
                hall: [
                    "Stood on a plinth like a figurehead. The indignity.",
                    "A whole hall of us, and not one tavern.",
                ],
            ),
            hall_dialogue_id: Some("hall_pirate_admiral"),
        ),
        "npc_pirate_raider": (
            sprite_tuning: Some((collision_scale: 1.6, frame_sample_inset: 1)),
            display_name: "Pirate Raider",
            spritesheet: "sprites/pirate_raider_spritesheet.png",
            manifest: "sprites/pirate_raider_spritesheet.ron",
            tier: MainHall,
            body_kind: Standard,
            composition: None,
            default_brain: "melee_brute_striker",
            default_action_set: "striker_swipe",
            tags: ["pirate", "enemy"],
        barks: (
            on_hit: ["Yarrrgh!", "Quit pokin' me loot hand!", "I'll swab the floor with ye!", "Yo-ho-NO, ye landlubber!"],
            provoked: ["Board 'em, lads — yo-ho!"],
            hall: ["A raider on display. The REAL plunder was the plinths we collected along the way.", "Yarr. The lighting in here is better than the cove.", "I could escape this exhibit. I choose not to."],
        ),
        hall_dialogue_id: Some("hall_npc_pirate_raider"),
        ),
        "npc_pirate_quartermaster": (
            sprite_target: Some("pirate_admiral"),
            sprite_tuning: Some((collision_scale: 1.6, frame_sample_inset: 1)),
            display_name: "Pirate Quartermaster",
            spritesheet: "sprites/pirate_quartermaster_spritesheet.png",
            manifest: "sprites/pirate_quartermaster_spritesheet.ron",
            tier: MainHall,
            body_kind: Standard,
            composition: None,
            default_brain: "melee_brute_striker",
            default_action_set: "striker_swipe",
            tags: ["pirate", "enemy"],
        barks: (
            on_hit: ["Inventory says NO, ye dock-rat!", "Yarr! Every coin's a-counted!", "Tally that on yer hide, swabbie!"],
            provoked: ["Pay the toll in teeth, swab!"],
            hall: ["I've counted every exhibit in this hall. Twice.", "The catalog is mine by rights. I've administered worse.", "Every character here owes me a cut. I'm keeping track."],
        ),
        hall_dialogue_id: Some("hall_npc_pirate_quartermaster"),
        ),
        "npc_pirate_lookout": (
            sprite_target: Some("pirate_admiral"),
            sprite_tuning: Some((collision_scale: 1.6, frame_sample_inset: 1)),
            display_name: "Pirate Lookout",
            spritesheet: "sprites/pirate_lookout_spritesheet.png",
            manifest: "sprites/pirate_lookout_spritesheet.ron",
            tier: MainHall,
            body_kind: Standard,
            composition: None,
            default_brain: "skirmisher_ranger",
            default_action_set: "ranger_arrow",
            tags: ["pirate", "enemy"],
        barks: (
            on_hit: ["Land ho — an' I see YE comin'!", "Spyglass to me eye, boots to yer head!", "Crow's nest don't sit empty, savvy?"],
            provoked: ["Sound the alarm — all hands!"],
            hall: ["Good sightlines from this plinth. I've assessed them.", "I spotted the exit three seconds after entering. Just saying.", "The Lookout watches. Even here. Especially here."],
        ),
        hall_dialogue_id: Some("hall_npc_pirate_lookout"),
        ),
        "npc_pirate_navigator": (
            sprite_target: Some("pirate_admiral"),
            sprite_tuning: Some((collision_scale: 1.6, frame_sample_inset: 1)),
            display_name: "Pirate Navigator",
            spritesheet: "sprites/pirate_navigator_spritesheet.png",
            manifest: "sprites/pirate_navigator_spritesheet.ron",
            tier: MainHall,
            body_kind: Standard,
            composition: None,
            default_brain: "skirmisher_ranger",
            default_action_set: "ranger_arrow",
            tags: ["pirate", "enemy"],
        barks: (
            on_hit: ["Wrong heading, ye chartless dog!", "I'll plot ye a course straight to Davy Jones!", "Compass says: punch back!"],
            provoked: ["Heading set: yer skull!"],
            hall: ["I've mapped this hall. The exits are where you'd expect.", "According to my charts, this plinth is slightly off-center. I've logged it.", "Navigation is about knowing where you are. I know exactly where I am."],
        ),
        hall_dialogue_id: Some("hall_npc_pirate_navigator"),
        ),

        // ===== Stochastic Parrot. ONE character, two factions: a friendly
        // cove bird (NpcSpawn -> this catalog row -> `patrol_peaceful`) and the
        // aggressive sky raiders (EnemySpawn name="Stochastic Parrot" -> the
        // `sky_parrot` enemy archetype, sprite bound by display-name match).
        // Both share this sprite + body via the actor unification.
        "stochastic_parrot": (
            sprite_tuning: Some((collision_scale: 1.0, frame_sample_inset: 1)),
            display_name: "Stochastic Parrot",
            spritesheet: "sprites/stochastic_parrot_spritesheet.png",
            manifest: "sprites/stochastic_parrot_spritesheet.ron",
            tier: MainHall,
            // Floating = gravity-free, so the lively Aerial brain flies it.
            body_kind: Floating,
            composition: None,
            default_brain: "parrot_lively",
            default_action_set: "peaceful",
            tags: ["pirate", "bird", "npc"],
            // SCAFFOLD exemplar. idle migrated from features::npcs (the
            // "parrot_cove" legacy pool, now keyed by catalog id).
            barks: (
                idle: [
                    "Awk! Polly wants a corpus.",
                    "Squawk! Next token... 'cracker'. High confidence.",
                    "I contain multitudes. Mostly other people's.",
                    "Pieces of prior! Pieces of prior!",
                    "Awk! I'm not parroting, I'm GENERALIZING. ...mostly.",
                    "Temperature's high today. Feeling creative. Brawk!",
                    "Attention is all you need! And crackers.",
                ],
                hall: [
                    "Awk! On display! Sampled, plinthed, labelled!",
                    "Next exhibit... 'cracker'. Brawk!",
                ],
            ),
            hall_dialogue_id: Some("hall_stochastic_parrot"),
        ),

        // ===== Perfect Cellular Automaton.
        // Python-authored Fable-extension skeletal target. VFX such as energy
        // or slash arcs are intentionally not baked into the sprite sheet.
        "perfect_cellular_automaton": (
            sprite_tuning: Some((collision_scale: 1.12, frame_sample_inset: 1)),
            display_name: "Perfect Cellular Automaton",
            spritesheet: "sprites/perfect_cellular_automaton_spritesheet.png",
            manifest: "sprites/perfect_cellular_automaton_spritesheet.ron",
            tier: MainHall,
            body_kind: Floating,
            composition: None,
            default_brain: "cellular_automaton_raider",
            default_action_set: "striker_swipe",
            tags: ["aerial", "enemy", "custom", "cellular"],
        barks: (
            on_hit: ["Iteration interrupted.", "State diverged from optimal.", "Rule violated. Adapting.", "Error. Correcting."],
            provoked: ["Initializing conflict state."],
            hall: ["Every generation leads inevitably here.", "I have computed all futures. In most, you leave.", "The museum is a fixed point. I accept it."],
        ),
        hall_dialogue_id: Some("hall_perfect_cellular_automaton"),
        ),
        "imperfect_cellular_automaton": (
            sprite_tuning: Some((collision_scale: 1.12, frame_sample_inset: 1)),
            display_name: "Imperfect Cellular Automaton",
            spritesheet: "sprites/imperfect_cellular_automaton_spritesheet.png",
            manifest: "sprites/imperfect_cellular_automaton_spritesheet.ron",
            tier: MainHall,
            body_kind: Floating,
            composition: None,
            default_brain: "cellular_automaton_raider",
            default_action_set: "striker_swipe",
            tags: ["aerial", "enemy", "custom", "cellular"],
        barks: (
            on_hit: ["Er — glitch — GAHH!", "That wasn't in the rule set!", "Malfunction cascade!", "Rulebase corrupted!"],
            provoked: ["All states hostile!"],
            hall: ["I am imperfect. The label makes it worse.", "My neighbor got the 'Perfect' prefix. I got this plinth.", "At least I'm in the catalog. That's something."],
        ),
        hall_dialogue_id: Some("hall_imperfect_cellular_automaton"),
        ),

        // ===== Pirate Heavy bruisers (slow + hard hitting).
        "npc_pirate_heavy_broadside_bess": (
            sprite_tuning: Some((collision_scale: 1.95, frame_sample_inset: 1)),
            display_name: "Broadside Bess",
            spritesheet: "sprites/pirate_heavy_broadside_bess_spritesheet.png",
            manifest: "sprites/pirate_heavy_broadside_bess_spritesheet.ron",
            tier: MainHall,
            body_kind: Wide,
            composition: None,
            default_brain: "melee_brute_brute",
            default_action_set: "brute_lunge",
            tags: ["pirate", "heavy", "enemy"],
        barks: (
            on_hit: ["Mind me cleaver, wee skipper!", "Aye, that smarts — but ye're worse off!", "Broadside Bess don't bend easy!", "Yarrrr! Take that an' a barrel more!"],
            provoked: ["Cleaver's thirsty — yarrrgh!"],
            hall: ["Broadside Bess. On a plinth. The plinth holds.", "They made the exhibit bigger to fit me. I appreciate the honesty.", "Bess has seen rougher crowds than this gallery."],
        ),
        hall_dialogue_id: Some("hall_npc_pirate_heavy_broadside_bess"),
        ),
        "npc_pirate_heavy_iron_mary": (
            sprite_tuning: Some((collision_scale: 1.95, frame_sample_inset: 1)),
            display_name: "Iron Mary",
            spritesheet: "sprites/pirate_heavy_iron_mary_spritesheet.png",
            manifest: "sprites/pirate_heavy_iron_mary_spritesheet.ron",
            tier: MainHall,
            body_kind: Wide,
            composition: None,
            default_brain: "melee_brute_brute",
            default_action_set: "brute_lunge",
            tags: ["pirate", "heavy", "enemy"],
        barks: (
            on_hit: ["Iron don't flinch, ye gull!", "Pry harder, swab — I'll rust ye flat!", "Yo-ho, an' a clout to the noggin!", "Try me on a calmer sea, landlubber!"],
            provoked: ["Iron Mary breaks ye in half!"],
            hall: ["Iron Mary. On display. The plinth is iron too. I checked.", "They said 'Iron' in the name. I accept this as accurate.", "The exhibit placard is bolted on. Mary approves."],
        ),
        hall_dialogue_id: Some("hall_npc_pirate_heavy_iron_mary"),
        ),
        "npc_pirate_heavy_salt_annet": (
            sprite_tuning: Some((collision_scale: 1.95, frame_sample_inset: 1)),
            display_name: "Salt Annet",
            spritesheet: "sprites/pirate_heavy_salt_annet_spritesheet.png",
            manifest: "sprites/pirate_heavy_salt_annet_spritesheet.ron",
            tier: MainHall,
            body_kind: Wide,
            composition: None,
            default_brain: "melee_brute_brute",
            default_action_set: "brute_lunge",
            tags: ["pirate", "heavy", "enemy"],
        barks: (
            on_hit: ["Salt in the eye, blood in the bilge!", "Yargh! Watch yer manners on me deck!", "Wee skipper thinks he's bold, does he?", "Annet bites back, every time!"],
            provoked: ["Wee skipper picked the wrong deck!"],
            hall: ["Salt Annet. Named and plinthed.", "The brine air doesn't reach this hall. Annet notes this.", "There are worse fates than a museum. Annet has encountered them."],
