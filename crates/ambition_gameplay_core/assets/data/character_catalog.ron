            provoked: ["You've made an enemy today."],
            idle: ["I have opinions about this situation.", "Things are proceeding as expected. Disappointingly.", "The system works. I've adapted to it."],
            hall: ["Ask precisely. I answer the words, not the wish.", "Every answer's correct. Whether it helps is on you."],
        ),
        hall_dialogue_id: Some("hall_npc_olivia"),
        ),
        "npc_peggy": (
