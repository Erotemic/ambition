            tags: ["enemy", "ranged"],
        barks: (
            on_hit: ["Arrow notched next time!", "Desert air burns both ways!", "That cost me an arrow!"],
            provoked: ["Drawing!"],
            hall: ["Desert goblin's eyes water in here. No sand to blame. Awkward.", "One arrow, one problem, solved before it gets close. Tidy."],
        ),
        hall_dialogue_id: Some("hall_npc_goblin_desert_bow"),
        ),
        "npc_goblin_forest_spear": (
            display_name: "Goblin Forest Spear",
