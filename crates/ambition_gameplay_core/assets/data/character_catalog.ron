        barks: (
            on_hit: ["This will be documented.", "Filed under: regrettable.", "Record updated: aggressor identified."],
            provoked: ["Permanent record updated. Unfavorably."],
            idle: ["Every interaction is a record. I keep them all.", "The archive is never complete.", "Ask me anything. I may or may not answer."],
            hall: ["I am the archivist on display. Recursively ironic.", "I have cataloged this hall. The catalog now contains the archivist who cataloged it.", "My plinth is the best organized. I organized it myself."],
