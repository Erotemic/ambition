            provoked: ["Dagger out!"],
            hall: ["Too bright. Cave goblin's eyes have OPINIONS.", "The thing you don't hear is the thing that gets you."],
        ),
        hall_dialogue_id: Some("hall_npc_goblin_cave_dagger"),
        ),
        "npc_goblin_desert_bow": (
            display_name: "Goblin Desert Bow",
