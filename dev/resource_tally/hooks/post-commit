#!/usr/bin/env bash
# Auto-record LLM resource usage for the commit just created.
#
# Install once (repo-local, not committed):
#     git config core.hooksPath dev/resource_tally/hooks
#
# Accounting must never block or fail a commit, so this is best-effort (`|| true`)
# and stays quiet on success.
root="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
python3 "$root/dev/resource_tally/resource_tally.py" record --commit HEAD >/dev/null 2>&1 || true
