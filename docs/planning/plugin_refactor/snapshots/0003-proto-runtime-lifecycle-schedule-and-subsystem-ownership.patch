+            )
+                .chain()
+                .in_set(crate::app::SandboxSet::PlayerSimulation)
+                .after(crate::app::player_simulation_system)
+                .after(crate::item_pickup::ground_item_physics)
+                .run_if(crate::gameplay_allowed),
+        );
+    }
+}
