// GNU-ton boss arena — tall underground chamber for the giant wildebeest fight.
//
// Rev: bumped to 1792×1280 (was 1536×896) so the player drops in from a
// ledge near the top and sees the whole GNU-ton silhouette before
// descending into striking range. The body sprite is z-layered behind
// platforms (see `presentation::rendering::actors::GnuTonBodyLayer`)
// so the player can read jump targets through the giant.
//
// Encounter flow:
//   1. Player enters from `hall_of_bosses` via the top-left LoadingZone.
//   2. Lands on the entry ledge, walks right onto a BreakablePlatform.
//   3. The platform breaks under their weight, forcing a descent into
//      the fight (they fall through a column of perches that catches
//      them safely before the floor).
//   4. Boss fight at floor level. GNU-ton's head is always damageable
//      but high up at rest — climb the perches to reach it, or wait for
//      the head-descent windows that bring it to player level.
//   5. After defeat, the player climbs back up the ladder column near
//      the spawn (the ladder is painted Climbable in IntGrid).
//
// Layout (1792 wide x 1280 tall):
//
//   +------------------------------------------------------------+ y=0
//   |▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒ ceiling ▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒|
//   | [door]   [ledge───][BreakablePad]                          | ← top entry
//   |  ▓ladder▓                                                  |
//   |  ▓ladder▓               ░░░░top perch░░░░                  |
//   |  ▓ladder▓                                                  |
//   |  ▓ladder▓        ┌─────[BossSpawn]─────┐                   | ← GNU-ton centered
//   |  ▓ladder▓        │   (220×220 box)     │                   |
//   |  ▓ladder▓        └─────────────────────┘                   |
//   |  ▓ladder▓   ░░perch left       perch right░░               |
//   |  ▓ladder▓                                                  |
//   |  ▓ladder▓       ░░perch mid-left   perch mid-right░░       |
//   |  ▓ladder▓                                                  |
//   |  ▓ladder▓                                                  |
//   |  ▓floor ▓░░perch left low    perch right low░░             |
//   |▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒ floor ▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒| y=1248
//   +------------------------------------------------------------+
//
// Ladder gating: the Climbable IntGrid below is painted unconditionally
// at world-load time, but the sandbox-side `gate_gnu_ton_arena_ladder`
// system (bosses/gnu_ton.rs) removes the Ladder regions from
// `world.climbable_regions` on entry and re-adds them the frame the
// gnu_ton (now gnu_ton_rider) boss is defeated. So the cells exist in
// LDtk but only count at runtime once the player has earned the retreat.
//
// REGEN SEQUENCE (this area is NOT single-step — the named floor-gate is a
// post-patch). After
//   `area create gnu_ton_arena_area.ron --ldtk sandbox.ldtk --replace-existing`,
// re-apply the two gate patches (the area spec lowers Solids to anonymous
// IntGrid, but the gate must be a NAMED Solid entity the runtime can remove):
//   1. `intgrid erase --level gnu_ton_arena --px 120,208 --size 32,16`
//      (carves the 48x16 slot out of the lowered entry_ledge)
//   2. `entity add specs/gnu_ton/add_ladder_floor_gate.yaml`
//      (adds the `ladder_floor_gate` named Solid entity into that slot)
// `specs/gnu_ton/lower_boss_spawn.yaml` is now OBSOLETE — the mount already
// spawns at px [786, 832] here (the fused BossSpawn it moved no longer exists).

(
    id: "gnu_ton_arena",
    level_id: "gnu_ton_arena",
    // World placement mirrors the live sandbox.ldtk slot (the gridvania layout
    // owns level positions; this spec tracks it so a `--replace-existing` regen
    // stays position-preserving rather than relocating the arena).
    world_x: 5120,
    world_y: 6656,
    px_wid: 1792,
    px_hei: 1280,
    fill_collision: "empty",
    biome: "boss",
    music_track: "standing_on_shoulders",
    ambient_profile: "hum",
    visual_theme: "default",
    intgrid: (
        climbable: [
            (
                kind: "Ladder",
                px: [
                    120,
                    224,
                ],
                size: [
                    32,
                    1024,
                ],
            ),
        ],
    ),
    entities: [
        (
            type: "Solid",
            px: [
                0,
                1248,
            ],
            size: [
                1792,
                32,
            ],
            fields: (
                name: "floor",
            ),
        ),
        (
            type: "Solid",
            px: [
                0,
                0,
            ],
            size: [
                16,
                1248,
            ],
            fields: (
                name: "left_wall",
            ),
        ),
        (
            type: "Solid",
            px: [
                1776,
                0,
            ],
            size: [
                16,
                1248,
            ],
            fields: (
                name: "right_wall",
            ),
        ),
        (
            type: "Solid",
            px: [
                16,
                0,
            ],
            size: [
                1760,
                16,
            ],
            fields: (
                name: "ceiling",
            ),
        ),
        (
            type: "Solid",
            px: [
                16,
                208,
            ],
            size: [
                288,
                16,
            ],
            fields: (
                name: "entry_ledge",
            ),
        ),
        (
            type: "BreakablePlatform",
            px: [
                304,
                208,
            ],
            size: [
                160,
                16,
            ],
            fields: (
                name: "spawn_descent_pad",
                collision: "Solid",
                trigger: "OnStand",
                respawn: "Never",
            ),
        ),
        (
            type: "OneWayPlatform",
            px: [
                752,
                432,
            ],
            size: [
                288,
                16,
            ],
            fields: (
                name: "perch_top_center",
            ),
        ),
        (
            type: "OneWayPlatform",
            px: [
                240,
                560,
            ],
            size: [
                192,
                16,
            ],
            fields: (
                name: "perch_left_high",
            ),
        ),
        (
            type: "OneWayPlatform",
            px: [
                1360,
                560,
            ],
            size: [
                192,
                16,
            ],
            fields: (
                name: "perch_right_high",
            ),
        ),
        (
            type: "OneWayPlatform",
            px: [
                528,
                720,
            ],
            size: [
                160,
                16,
            ],
            fields: (
                name: "perch_left_mid_high",
            ),
        ),
        (
            type: "OneWayPlatform",
            px: [
                1104,
                720,
            ],
            size: [
                160,
                16,
            ],
            fields: (
                name: "perch_right_mid_high",
            ),
        ),
        (
            type: "OneWayPlatform",
            px: [
                752,
                832,
            ],
            size: [
                288,
                16,
            ],
            fields: (
                name: "perch_center_main",
            ),
        ),
        (
            type: "OneWayPlatform",
            px: [
                336,
                944,
            ],
            size: [
                192,
                16,
            ],
            fields: (
                name: "perch_left_mid",
            ),
        ),
        (
            type: "OneWayPlatform",
            px: [
                1264,
                944,
            ],
            size: [
                192,
                16,
            ],
            fields: (
                name: "perch_right_mid",
            ),
        ),
        (
            type: "OneWayPlatform",
            px: [
                192,
                1088,
            ],
            size: [
                224,
                16,
            ],
            fields: (
                name: "perch_left_low",
            ),
        ),
        (
            type: "OneWayPlatform",
            px: [
                1376,
                1088,
            ],
            size: [
                224,
                16,
            ],
            fields: (
                name: "perch_right_low",
            ),
        ),
        (
            type: "PlayerStart",
            px: [
                368,
                162,
            ],
            size: [
                28,
                46,
            ],
            fields: (
                name: "gnu_ton_arena_spawn",
            ),
        ),
        (
            type: "LoadingZone",
            px: [
                64,
                112,
            ],
            size: [
                48,
                96,
            ],
            fields: (
                id: "gnu_ton_arena_exit",
                name: "gnu_ton_arena_exit",
                activation: "Door",
                target_room: "hall_of_bosses",
                target_zone: "hall_gnu_ton_portal",
                bidirectional: true,
            ),
        ),
        // ADR 0020 (G4): GNU-ton is authored as a LINKED PAIR — a brainless
        // `giant_gnu` EnemySpawn MOUNT carrying the giant's 220x220 envelope, and
        // a `gnu_ton_rider` BossSpawn RIDER (the scholar, the encounter boss)
        // welded to the giant's saddle via a `mounted_on` EntityRef. The mount
        // carries no explicit `id`, so its runtime FeatureId == its iid — exactly
        // the target the rider's ref stores, which `resolve_pending_mount_links`
        // matches. `spawn_boss` attaches the rider's CanPilot("giant"); G3's limb
        // router drives the giant's hands from the rider's authored strikes.
        (
            type: "EnemySpawn",
            ref: "giant_gnu_mount",
            px: [
                786,
                832,
            ],
            size: [
                220,
                220,
            ],
            fields: (
                name: "Giant GNU",
                brain: "giant_gnu",
            ),
        ),
        (
            type: "BossSpawn",
            px: [
                869,
                754,
            ],
            size: [
                54,
                96,
            ],
            fields: (
                name: "GNU-ton",
                brain: "PhaseScript:gnu_ton_rider",
                mounted_on: "giant_gnu_mount",
            ),
        ),
        (
            type: "CameraZone",
            px: [
                0,
                0,
            ],
            size: [
                1792,
                1280,
            ],
            fields: (
                id: "gnu_ton_arena_camera",
                name: "gnu_ton_arena_camera",
                mode: "Default",
                zoom: 1.25,
            ),
        ),
        (
            type: "DebugLabel",
            px: [
                128,
                1216,
            ],
            size: [
                1536,
                20,
            ],
            fields: (
                name: "gnu_ton_arena_label",
                text: "GNU-ton — drop in from above; strike the head when it descends.",
                category: "Custom",
            ),
        ),
    ],
)
