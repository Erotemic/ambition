// Test-access door: central_hub_main → intro_wake_room.
//
// Placement: on the one-way platform mid-room, directly under the
// `hub routing note` PogoOrb. Coordinates picked via:
//
//   python -m ambition_ldtk_tools door snap central_hub_main \
//     --x 908 --door-w 48 --door-h 96 --prefer-y 522
//   → snap x=908 y=624 surface=OneWayUp
//
// Verified via:
//
//   python -m ambition_ldtk_tools entity check --level central_hub_main \
//     --px 908,624 --size 48,96 --ignore CameraZone
//   → no overlap; nearest neighbor = PogoOrb at 74.2px center
//     (intentional — the door sits directly below the orb).
//
// This door is the only way into the intro for now. Move it again
// with `entity delete` + this spec re-edited rather than hand-
// editing the LDtk JSON.
//
// Run:
//   python -m ambition_ldtk_tools entity add \
//     tools/ambition_ldtk_tools/specs/intro_entry_door_in_central_hub_main.yaml \
//     --ldtk crates/ambition_content/assets/worlds/sandbox.ldtk \
//     --in-place

(
    level_id: "central_hub_main",
    entities: [
        (
            type: "LoadingZone",
            px: [
                908,
                624,
            ],
            size: [
                48,
                96,
            ],
            fields: (
                id: "intro_wake_door",
                name: "intro_wake_door",
                activation: "Door",
                target_room: "intro_wake_room",
                target_zone: "wake_room_arrival",
                bidirectional: true,
            ),
        ),
    ],
)
