// Mockingbird boss arena — open vertical room behind the pirate cove.
// The Mockingbird floats in the center of the room and uses the
// `mockingbird` BossPatternSchedule (Hover → Swoop → Fireball →
// Swoop) registered in `crates/ambition_engine/src/boss_patterns.rs`.
//
// Layout (960 wide × 768 tall — wide enough for the dash-distance
// swoops, tall enough that hover beats read as "above the player"):
//
//   +------------------------------------------+  y = 0
//   | ▒▒▒▒▒▒▒▒▒▒▒▒ ceiling ▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒  |
//   |                                          |
//   |               [BossSpawn]                |  ← boss spawns here,
//   |                                          |    free-flying
//   |                                          |
//   |                                          |
//   |  ░░ one-way perch ░░    ░░ perch ░░     |  ← player platforming
//   |                                          |
//   |  [exit door]                             |  ← back to cove
//   | ▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒  | y = 736 (floor)
//   +------------------------------------------+
//
// Music: `how_to_kill_a_mockingbird` — the mockingbird-specific
// track defined in `tools/ambition_music_renderer/scores/active/`.
// When the audio asset is rendered + installed the boss encounter
// spec will pick it up; until then the music system falls back to
// whatever is registered as "default boss" in the cue catalog.

(
    id: "mockingbird_arena",
    level_id: "mockingbird_arena",
    world_x: -10000,
    world_y: 0,
    px_wid: 960,
    px_hei: 768,
    fill_collision: "empty",
    biome: "cove",
    music_track: "how_to_kill_a_mockingbird",
    ambient_profile: "tide",
    visual_theme: "blue",
