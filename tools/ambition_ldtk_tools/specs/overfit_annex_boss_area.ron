// Overfit Annex — the finale: a boss arena off the vault, turning the annex
// (hub → combat → climb → vault) into a complete DUNGEON. Reuses Mode Collapse
// (a summoner — it floods the room, a fitting dungeon climax). connect_to places
// the vault→boss door on the vault's right side.
(
    id: "overfit_annex_boss",
    level_id: "overfit_annex_boss",
    world_x: 62000,
    world_y: 1024,
    px_wid: 1280,
    px_hei: 640,
    fill_collision: "empty",
    bg_color: "#120E18",
    biome: "lab",
    entities: [
        ( type: "Solid", px: [0, 608], size: [1280, 32], fields: ( name: "floor" ) ),
        ( type: "Solid", px: [0, 0], size: [1280, 16], fields: ( name: "ceiling" ) ),
        ( type: "Solid", px: [0, 16], size: [16, 592], fields: ( name: "left_wall" ) ),
        ( type: "Solid", px: [1264, 16], size: [16, 592], fields: ( name: "right_wall" ) ),
        ( type: "PlayerStart", px: [120, 562], size: [28, 46], fields: ( name: "overfit_annex_boss_spawn" ) ),
        ( type: "BossSpawn", px: [640, 360], size: [140, 132], fields: ( name: "Mode Collapse", brain: "PhaseScript:mode_collapse_boss" ) ),
        (
            type: "LoadingZone",
            px: [16, 512],
            size: [48, 96],
            fields: ( id: "overfit_annex_boss_to_vault", name: "overfit_annex_boss_to_vault", activation: "Door", target_room: "overfit_annex_vault", target_zone: "overfit_annex_vault_boss_door", bidirectional: true ),
        ),
        ( type: "CameraZone", px: [0, 0], size: [1280, 640], fields: ( id: "overfit_annex_boss_camera", name: "overfit_annex_boss_camera", mode: "Encounter" ) ),
        ( type: "DebugLabel", px: [120, 80], size: [640, 24], fields: ( name: "overfit_annex_boss_label", text: "The annex core — Mode Collapse floods the room. Clear it.", category: "Custom" ) ),
    ],
    connect_to: [
        ( target_room: "overfit_annex_vault", px: [704, 256], size: [16, 96], id: "overfit_annex_vault_boss_door", target_zone: "overfit_annex_boss_to_vault", activation: "Door", bidirectional: true ),
    ],
)
