            size: [48, 96],
            fields: ( id: "overfit_annex_climb_to_entry", name: "overfit_annex_climb_to_entry", activation: "Door", target_room: "overfit_annex_entry", target_zone: "overfit_annex_entry_climb_door", bidirectional: true ),
        ),
        ( type: "CameraZone", px: [0, 0], size: [1280, 512], fields: ( id: "overfit_annex_climb_camera", name: "overfit_annex_climb_camera", mode: "Default" ) ),
        ( type: "DebugLabel", px: [70, 96], size: [620, 24], fields: ( name: "overfit_annex_climb_label", text: "Climb the steps to the vault above.", category: "Custom" ) ),
    ],
