// Add a `water_door` LoadingZone to central_hub_basement so the
// basement-hub fans out to the new water_world. Pairs with
// `water_world/return_door`. Placement: leftmost free slot, before
// hazard_door (cells 5-7, between left wall and hazard_door at cell 15).

(
    level_id: "central_hub_basement",
    entities: [
        (
            type: "LoadingZone",
            px: [
                80,
                832,
            ],
            size: [
                48,
                96,
            ],
            fields: (
                id: "water_door",
                name: "water_world",
                activation: "Door",
                target_room: "water_world",
                target_zone: "return_door",
                bidirectional: false,
            ),
        ),
    ],
)
